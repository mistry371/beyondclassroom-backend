# Beyond Classroom backend — production env template.
# Copy to server/.env on the EC2 host and fill real values. NEVER commit real secrets.

PORT=5000
NODE_ENV=production
JWT_SECRET=change-me-to-a-long-random-string

# MongoDB (text/data stays in Mongo). Use your Atlas cluster.
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/beyondclassroom?retryWrites=true&w=majority

# Frontend origin (for CORS). Set to your deployed frontend URL.
FRONTEND_URL=https://beyondclassroom.netlify.app

# AWS S3 — document/file storage (files → S3, only URLs stored in Mongo).
# STRONGLY RECOMMENDED: use a scoped IAM user with S3-only permissions here,
# NOT root keys. Better yet, attach an IAM Role to the EC2 instance and omit
# these two lines entirely (the SDK picks up the role automatically).
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=beyondclassroom-docs
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Email delivery — prefer Resend (works from AWS; SMTP egress may be filtered).
# RESEND_API_KEY=re_...
# EMAIL_FROM=Beyond Classroom <no-reply@yourdomain.com>
EMAIL_USER=beyondclassroom247@gmail.com
EMAIL_PASS=your_gmail_app_password

# Razorpay (live)
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx

# Zoom
ZOOM_ACCOUNT_ID=xxx
ZOOM_CLIENT_ID=xxx
ZOOM_CLIENT_SECRET=xxx
ZOOM_USER_ID=me
