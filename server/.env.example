PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here_change_in_production

# MongoDB - set your Atlas SRV connection string
# URL-encode special chars in password: @ → %40, # → %23, $ → %24
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/beyondclassroom?retryWrites=true&w=majority&appName=Cluster0

# Frontend URL (for CORS)
FRONTEND_URL=https://beyondclassroom.netlify.app

# Email (Gmail App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Zoom Server-to-Server OAuth
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_USER_ID=me
